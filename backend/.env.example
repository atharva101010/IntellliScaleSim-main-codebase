# IntelliScaleSim Backend Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# SQLite (Development)
DATABASE_URL=sqlite:///./app.db

# PostgreSQL (Production - use with docker-compose)
# DATABASE_URL=postgresql://intelliscale:intelliscale_secure_password@intelliscale-postgres:5432/intelliscale

# ===========================================
# SECURITY
# ===========================================
# Generate a secure key with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# REDIS CONFIGURATION (Optional - for caching)
# ===========================================
REDIS_URL=redis://localhost:6379/0
# For Docker:
# REDIS_URL=redis://intelliscale-redis:6379/0

# ===========================================
# DOCKER HUB CREDENTIALS (Optional - for private images)
# ===========================================
DOCKER_HUB_USERNAME=
DOCKER_HUB_PASSWORD=

# ===========================================
# EMAIL CONFIGURATION (for password reset, etc.)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@intelliscale.com

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=IntelliScaleSim
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ===========================================
# CORS SETTINGS
# ===========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ===========================================
# MONITORING
# ===========================================
PROMETHEUS_ENABLED=true
METRICS_PATH=/metrics
