# IntelliScaleSim VPS deployment environment
# Copy this file to .env.vps and replace all placeholder values before deploy.

# Public DNS domain that points to your VPS (A record)
DOMAIN=your-domain.com

# Email used by Let's Encrypt (Caddy ACME account)
ACME_EMAIL=admin@your-domain.com

# Database
POSTGRES_USER=intelliscale
POSTGRES_PASSWORD=change-this-strong-db-password
POSTGRES_DB=intelliscale_db

# App security
APP_ENV=production
JWT_SECRET=change-this-to-a-long-random-secret

# AI integration (optional but recommended for full functionality)
GROQ_API_KEY=

# Grafana admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-strong-grafana-password

# CORS (comma-separated)
CORS_ORIGINS=https://your-domain.com

# Optional override (if you use external Supabase PostgreSQL)
# SUPABASE_DB_URL=postgresql://user:pass@host:6543/postgres

# Optional frontend API override (defaults to https://${DOMAIN}/api)
# VITE_API_URL=https://your-domain.com/api
